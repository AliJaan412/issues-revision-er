# Copy this file to .env and fill in real values. Never commit .env.

# --- App server ---
# Port the Node app listens on (used directly by `npm start`).
PORT=8080
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1h

# --- Database connection (used directly by `npm start`) ---
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=replace-with-a-strong-password
DB_NAME=issue_db
DB_PORT=3306

# --- docker-compose only ---
# docker-compose.yml maps these into the containers' PORT/DB_* variables above,
# so the app container never needs its own values for the block below.
MYSQLDB_ROOT_PASSWORD=replace-with-a-strong-password
MYSQLDB_DATABASE=issue_db
MYSQLDB_USER=root
MYSQLDB_LOCAL_PORT=3306
MYSQLDB_DOCKER_PORT=3306
NODE_LOCAL_PORT=8080
NODE_DOCKER_PORT=8080
